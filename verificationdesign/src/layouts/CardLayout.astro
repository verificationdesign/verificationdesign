---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CardNav from '../components/CardNav.astro';
import { getUi } from '../i18n/ui';
import { cardSourceUrl, REPO_ISSUES_URL } from '../lib/repo';

const { entry, headings, prev, next } = Astro.props;
const data = entry.data;
const t = getUi();

const breadcrumb = [
  { label: t.card.breadcrumbRoot, href: t.routes.patterns },
  { label: data.categoryLabel, href: `/patterns/#${data.category}` },
  { label: data.title },
];

const sectionHeadings = (headings || []).filter((h: any) => h.depth === 2);
const description = data.intent ??
  `${data.title}: an AI design pattern in the ${data.categoryLabel} family.`;

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const cardSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: data.title,
    description,
    dateModified: data.updated,
    url: pageUrl,
    isPartOf: {
      '@type': 'WebSite',
      name: t.siteName,
      url: Astro.site?.toString(),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumb.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.label,
      ...(item.href ? { item: new URL(item.href, Astro.site).toString() } : {}),
    })),
  },
]);
---

<BaseLayout title={data.title} description={description} updated={data.updated}>
  <article class="card-page">
    <script is:inline type="application/ld+json" set:html={cardSchema} />
    <Breadcrumb items={breadcrumb} />

    {sectionHeadings.length > 0 && (
      <details class="section-nav">
        <summary>{t.card.sections}</summary>
        <ol>
          {sectionHeadings.map((h: any) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
      </details>
    )}

    <div class="card-body">
      <slot />
    </div>

    <p class="card-updated">
      {t.card.updated} {data.updated} ·
      <a href={cardSourceUrl(data.slug)}>{t.card.viewSource}</a> ·
      <a href={REPO_ISSUES_URL}>{t.card.reportError}</a>
    </p>

    <CardNav prev={prev} next={next} />
  </article>
</BaseLayout>
