{
  "name": "verificationdesign",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint:cards": "python3 ../ai-design-patterns/scripts/lint_patterns.py",
